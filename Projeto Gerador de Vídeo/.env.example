# Video Generator - Configurações
# Copie este arquivo para .env e ajuste conforme necessário

# Servidor
SERVER_HOST=0.0.0.0
SERVER_PORT=5001
SERVER_DEBUG=false

# Chrome
CHROME_PROFILE_DIR=C:\chrome_profile_automation
CHROME_HEADLESS=false

# Processamento
WAIT_BETWEEN_SCENES=180
MAX_RETRIES=3
RESTART_BROWSER_INTERVAL=5

# Timeouts (segundos)
DALLE_GENERATION_TIMEOUT=180
GROK_GENERATION_TIMEOUT=420
DOWNLOAD_TIMEOUT=120
IMAGE_LOAD_TIMEOUT=30
BROWSER_CONFIRM_TIMEOUT=300

# Output
OUTPUT_DIR=./output
LOG_DIR=./logs

# Debug
DEBUG_SCREENSHOTS=false
DEBUG_SCREENSHOT_DIR=./output/debug
